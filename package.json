{
  "name": "g2-vega-hud",
  "version": "0.3.1",
  "description": "Even Realities G2 heads-up client for VEGA.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "build:packaged": "VITE_DISABLE_ENV_CONFIG=1 tsc && vite build",
    "pack": "npm run version:even && npm run build:packaged && evenhub pack app.json ./dist --output vega-hud.ehpk",
    "preview": "vite preview --host 0.0.0.0",
    "simulator": "evenhub-simulator http://localhost:5173",
    "qr": "evenhub qr --port 5173",
    "version:even": "node scripts/bump-even-version.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
