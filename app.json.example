{
  "package_id": "com.danielnguyen.vegahud",
  "edition": "202601",
  "name": "VEGA HUD",
  "description": "Even Realities G2 heads-up client for VEGA.",
  "version": "0.3.1",
  "min_app_version": "0.0.1",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "supported_languages": [
    "en"
  ],
  "permissions": [
    {
      "name": "network",
      "desc": "Connects to the private VEGA gateway.",
      "whitelist": [
        "https://your-gateway-host.example"
      ]
    }
  ]
}
